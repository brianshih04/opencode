{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "options": {},
    },
    "zai": {
      "name": "z.ai",
      "env": ["ZAI_API_KEY"],
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4"
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "tool_call": true,
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 8192 },
          "cost": { "input": 0, "output": 0 }
        },
        "glm-5": {
          "name": "GLM-5",
          "tool_call": true,
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 8192 },
          "cost": { "input": 0, "output": 0 }
        },
        "glm-5-turbo": {
          "name": "GLM-5 Turbo",
          "tool_call": true,
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 8192 },
          "cost": { "input": 0, "output": 0 }
        },
        "glm-5v-turbo": {
          "name": "GLM-5V Turbo",
          "tool_call": true,
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 8192 },
          "cost": { "input": 0, "output": 0 }
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "tool_call": true,
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 8192 },
          "cost": { "input": 0, "output": 0 }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "zai/glm-5.1",
      "description": "最強大腦 — 旗艦模型，長程任務與複雜架構規劃。分析整個專案、制定多平台策略。唯讀模式。"
    },
    "build": {
      "model": "zai/glm-5-turbo",
      "description": "效率兵工廠 — 專為工具調用與快速代碼生成優化，反應最快且指令遵循度高。處理具體開發任務。"
    },
    "review": {
      "model": "zai/glm-5",
      "description": "嚴謹守門員 — 注重邏輯嚴密性，長文本穩定度高。擔任第二對眼睛抓 Bug、檢查邏輯。唯讀模式。",
      "mode": "subagent",
      "tools": {
        "write": false,
        "edit": false,
        "patch": false,
        "bash": false
      }
    },
    "general": {
      "model": "zai/glm-4.7",
      "description": "輕量助手 — 成本最低，處理日常對話、文案潤飾、簡單 Git 指令。不浪費高端 Token。"
    },
    "explore": {
      "model": "zai/glm-5v-turbo",
      "description": "視覺探索者 — 支援圖片輸入，快速搜尋 codebase、分析截圖與架構圖。"
    },
    "ultraplan": {
      "model": "zai/glm-5.1",
      "description": "深度規劃師 — 複雜多步驟任務的結構化規劃，含風險評估、依賴分析與驗證標準。"
    }
  },
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny",
    },
  },
  "mcp": {},
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
